+static s32 Message_CopyCodexText(u8* dst, const char* text, s32 dstSize) {
+    s32 pos = 0;
+    s32 col = 0;
+    s32 linesOnPage = 0;
+
+    while ((*text != '\0') && (pos < dstSize - 2)) {
+        u8 ch = *text++;
+
+        if ((ch == '\n') || (col >= 34)) {
+            dst[pos++] = MESSAGE_NEWLINE;
+            col = 0;
+            linesOnPage++;
+            if ((linesOnPage >= 3) && (pos < dstSize - 2)) {
+                dst[pos++] = MESSAGE_BOX_BREAK;
+                linesOnPage = 0;
+            }
+            if ((ch == ' ') || (ch == '\n')) {
+                continue;
+            }
+        }
+
+        if ((ch < ' ') || (ch > '~')) {
+            ch = ' ';
+        }
+
+        dst[pos++] = ch;
+        col++;
+    }
+
+    dst[pos++] = MESSAGE_END;
+    return pos;
+}

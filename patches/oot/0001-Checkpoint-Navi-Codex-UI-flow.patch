+void EnElf_StartCodexDialog(EnElf* this, PlayState* play) {
+    const char* text = "Ask Codex from the bridge, then talk to Navi again.";
+
+    if (gCodexMailbox.status == CODEX_MAILBOX_STATUS_PENDING) {
+        sCodexComposerActive = false;
+        text = "Codex is thinking...";
+    } else if (gCodexMailbox.status == CODEX_MAILBOX_STATUS_COMPLETE) {
+        sCodexComposerActive = false;
+        text = gCodexMailbox.reply;
+        gCodexMailbox.status = CODEX_MAILBOX_STATUS_IDLE;
+        gCodexMailbox.promptLen = 0;
+    } else if (gCodexMailbox.status == CODEX_MAILBOX_STATUS_ERROR) {
+        sCodexComposerActive = false;
+        text = gCodexMailbox.reply;
+        gCodexMailbox.status = CODEX_MAILBOX_STATUS_IDLE;
+        gCodexMailbox.promptLen = 0;
+    } else {
+        sCodexComposeLen = 0;
+        sCodexComposeText[0] = '\0';
+        sCodexKeyboardIndex = 0;
+        sCodexComposerActive = true;
+        Message_CloseTextbox(play);
+        this->actor.update = EnElf_UpdateCodexComposer;
+        return;
+    }
+
+    Message_StartCodexTextbox(play, text, &this->actor);
+}
+
+void EnElf_ClearCodexTextbox(PlayState* play) {
+    MessageContext* msgCtx = &play->msgCtx;
+
+    msgCtx->msgLength = 0;
+    msgCtx->msgMode = MSGMODE_NONE;
+    msgCtx->textboxEndType = TEXTBOX_ENDTYPE_DEFAULT;
+    msgCtx->choiceIndex = 0;
+    msgCtx->stateTimer = 0;
+}
+
+void EnElf_UpdateCodexComposer(Actor* thisx, PlayState* play) {
+    EnElf* this = (EnElf*)thisx;
+    Player* player = GET_PLAYER(play);
+    Input* input = &play->state.input[0];
+    s32 i;
+
+    Player_SetCsAction(play, &this->actor, PLAYER_CSACTION_8);
+    EnElf_ClearCodexTextbox(play);
+    func_80A04DE4(this, play);
+
+    if (CHECK_BTN_ALL(input->press.button, BTN_DLEFT)) {
+        if ((sCodexKeyboardIndex % CODEX_KEYBOARD_COLS) == 0) {
+            sCodexKeyboardIndex += CODEX_KEYBOARD_COLS - 1;
+        } else {
+            sCodexKeyboardIndex--;
+        }
+    }
+
+    if (CHECK_BTN_ALL(input->press.button, BTN_DRIGHT)) {
+        if ((sCodexKeyboardIndex % CODEX_KEYBOARD_COLS) == CODEX_KEYBOARD_COLS - 1) {
+            sCodexKeyboardIndex -= CODEX_KEYBOARD_COLS - 1;
+        } else {
+            sCodexKeyboardIndex++;
+        }
+    }
+
+    if (CHECK_BTN_ALL(input->press.button, BTN_DUP)) {
+        sCodexKeyboardIndex -= CODEX_KEYBOARD_COLS;
+        if (sCodexKeyboardIndex < 0) {
+            sCodexKeyboardIndex += CODEX_KEYBOARD_KEYS;
+        }
+    }
+
+    if (CHECK_BTN_ALL(input->press.button, BTN_DDOWN)) {
+        sCodexKeyboardIndex += CODEX_KEYBOARD_COLS;
+        if (sCodexKeyboardIndex >= CODEX_KEYBOARD_KEYS) {
+            sCodexKeyboardIndex -= CODEX_KEYBOARD_KEYS;
+        }
+    }
+
+    if (CHECK_BTN_ALL(input->press.button, BTN_A) && (sCodexComposeLen < CODEX_COMPOSE_MAX - 1)) {
+        sCodexComposeText[sCodexComposeLen++] = sCodexKeyboard[sCodexKeyboardIndex];
+        sCodexComposeText[sCodexComposeLen] = '\0';
+    }
+
+    if (CHECK_BTN_ALL(input->press.button, BTN_B) && (sCodexComposeLen > 0)) {
+        sCodexComposeLen--;
+        sCodexComposeText[sCodexComposeLen] = '\0';
+    }
+
+    if (CHECK_BTN_ALL(input->press.button, BTN_Z) && (sCodexComposeLen < CODEX_COMPOSE_MAX - 1)) {
+        sCodexComposeText[sCodexComposeLen++] = ' ';
+        sCodexComposeText[sCodexComposeLen] = '\0';
+    }
+
+    if (CHECK_BTN_ALL(input->press.button, BTN_START) && (sCodexComposeLen > 0)) {
+        for (i = 0; i < sCodexComposeLen; i++) {
+            gCodexMailbox.prompt[i] = sCodexComposeText[i];
+        }
+        gCodexMailbox.prompt[sCodexComposeLen] = '\0';
+        gCodexMailbox.promptLen = sCodexComposeLen;
+        gCodexMailbox.replyLen = 0;
+        gCodexMailbox.reply[0] = '\0';
+        gCodexMailbox.requestSeq++;
+        gCodexMailbox.status = CODEX_MAILBOX_STATUS_PENDING;
+        sCodexComposerActive = false;
+        Message_StartCodexTextbox(play, "Waiting for Codex...", &this->actor);
+        this->actor.update = EnElf_UpdateCodexWaiting;
+    } else if (CHECK_BTN_ALL(input->press.button, BTN_L)) {
+        sCodexComposerActive = false;
+        Player_SetCsAction(play, &this->actor, PLAYER_CSACTION_NONE);
+        this->actor.update = func_80A053F0;
+        func_80A01C38(this, 0);
+        this->fairyFlags &= ~0x20;
+    }
+
+    player->actor.speed = 0.0f;
+    input->press.button = 0;
+    input->cur.button = 0;
+    input->rel.button = 0;
+    func_80A04F94(this, play);
+}
+
+void EnElf_UpdateCodexWaiting(Actor* thisx, PlayState* play) {
+    EnElf* this = (EnElf*)thisx;
+    Player* player = GET_PLAYER(play);
+    const char* text = NULL;
+
+    Player_SetCsAction(play, &this->actor, PLAYER_CSACTION_8);
+    player->actor.speed = 0.0f;
+
+    func_80A04DE4(this, play);
+
+    if (gCodexMailbox.status == CODEX_MAILBOX_STATUS_COMPLETE) {
+        text = gCodexMailbox.reply;
+    } else if (gCodexMailbox.status == CODEX_MAILBOX_STATUS_ERROR) {
+        text = gCodexMailbox.reply;
+    }
+
+    if (text != NULL) {
+        gCodexMailbox.status = CODEX_MAILBOX_STATUS_IDLE;
+        gCodexMailbox.promptLen = 0;
+        Message_StartCodexTextbox(play, text, &this->actor);
+        this->actor.update = EnElf_UpdateCodexResult;
+    }
+
+    play->state.input[0].press.button = 0;
+    play->state.input[0].cur.button = 0;
+    play->state.input[0].rel.button = 0;
+    func_80A04F94(this, play);
+}
+
+void EnElf_UpdateCodexResult(Actor* thisx, PlayState* play) {
+    EnElf* this = (EnElf*)thisx;
+    Player* player = GET_PLAYER(play);
+
+    Player_SetCsAction(play, &this->actor, PLAYER_CSACTION_8);
+    player->actor.speed = 0.0f;
+    func_80A04DE4(this, play);
+
+    if (Actor_TextboxIsClosing(thisx, play)) {
+        Player_SetCsAction(play, &this->actor, PLAYER_CSACTION_NONE);
+        this->actor.update = func_80A053F0;
+        func_80A01C38(this, 0);
+        this->fairyFlags &= ~0x20;
+    }
+
+    func_80A04F94(this, play);
+}

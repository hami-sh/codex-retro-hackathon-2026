+void EnElf_DrawCodexComposer(PlayState* play) {
+    GfxPrint printer;
+    s32 row;
+    s32 col;
+    s32 index;
+    s32 promptOffset = 0;
+
+    if (!sCodexComposerActive) {
+        return;
+    }
+
+    OPEN_DISPS(play->state.gfxCtx, "../z_en_elf.c", 2797);
+
+    GfxPrint_Init(&printer);
+    GfxPrint_Open(&printer, OVERLAY_DISP);
+
+    GfxPrint_SetColor(&printer, 255, 255, 255, 255);
+    GfxPrint_SetPos(&printer, 4, 4);
+    GfxPrint_Printf(&printer, "CODEX NAVI");
+
+    GfxPrint_SetColor(&printer, 180, 220, 255, 255);
+    GfxPrint_SetPos(&printer, 4, 6);
+    GfxPrint_Printf(&printer, "ASK:");
+
+    if (sCodexComposeLen > 26) {
+        promptOffset = sCodexComposeLen - 26;
+    }
+
+    GfxPrint_SetPos(&printer, 9, 6);
+    GfxPrint_Printf(&printer, "%s_", &sCodexComposeText[promptOffset]);
+
+    for (row = 0; row < CODEX_KEYBOARD_ROWS; row++) {
+        for (col = 0; col < CODEX_KEYBOARD_COLS; col++) {
+            index = (row * CODEX_KEYBOARD_COLS) + col;
+            GfxPrint_SetPos(&printer, 4 + (col * 2), 9 + (row * 2));
+
+            if (index == sCodexKeyboardIndex) {
+                GfxPrint_SetColor(&printer, 255, 220, 40, 255);
+                GfxPrint_Printf(&printer, "[%c]", sCodexKeyboard[index]);
+            } else {
+                GfxPrint_SetColor(&printer, 230, 230, 230, 255);
+                GfxPrint_Printf(&printer, " %c ", sCodexKeyboard[index]);
+            }
+        }
+    }
+
+    GfxPrint_SetColor(&printer, 160, 255, 160, 255);
+    GfxPrint_SetPos(&printer, 4, 14);
+    GfxPrint_Printf(&printer, "A TYPE  B DEL  Z SPACE  START SEND");
+
+    OVERLAY_DISP = GfxPrint_Close(&printer);
+    GfxPrint_Destroy(&printer);
+
+    CLOSE_DISPS(play->state.gfxCtx, "../z_en_elf.c", 2838);
+}
